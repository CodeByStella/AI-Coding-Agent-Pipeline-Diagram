    },
    "features": {
      "layout": "three_column_cards",
      "items": [
        { "title": "Fast", "body": "Short description." },
        { "title": "Safe", "body": "Short description." },
        { "title": "Observable", "body": "Short description." }
      ]
    }
  },
  "tokens": {
    "color": { "primary": "#0f172a", "accent": "#22c55e", "surface": "#ffffff" },
    "spacing": { "md": 16, "lg": 24, "xl": 32 },
    "radius": { "card": 8 }
  }
}
