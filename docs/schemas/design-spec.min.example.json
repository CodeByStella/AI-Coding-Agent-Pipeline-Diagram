{
  "schemaVersion": 1,
  "productName": "Example SaaS",
  "audience": "Small product teams",
  "routes": [
    {
      "id": "landing",
      "path": "/",
      "sections": ["hero", "features", "pricing", "faq", "footer"]
    }
  ],
  "sections": {
    "hero": {
      "layout": "two_column",
      "headline": "Ship faster with clarity",
